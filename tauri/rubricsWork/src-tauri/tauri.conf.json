{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rubricswork",
  "version": "0.1.13",
  "identifier": "com.oncfuturee.rubricswork",
  "build": {
    "beforeDevCommand": "npm run prepare-workbenches && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/before-tauri-build.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rubrics 工作台启动器",
        "width": 800,
        "height": 480,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/workbench-dist/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
